{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "outDir": ".",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false,
    "noEmit": true,
    "strict": true,
    "alwaysStrict": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": [
    "types/**/*.d.ts",
    "src/types.d.ts",
    "src/core/*/index.ts",
    "examples/*/index.ts",
    "src/**/*.ts"
  ],
  "exclude": ["node_modules", ".venv", "dev", "**/__tests__/**", "src/old"]
}
